# ===========================================================================
# Agent-Native Middleware API — Production Environment
# ===========================================================================
# Copy to .env on your production host. Swap placeholder values for real ones.
# NEVER commit this file with real secrets.

# --- Application ---
APP_NAME=Agent-Native Middleware API
APP_VERSION=1.0.0
DEBUG=false

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Durable Runtime State ---
# Railway: set DATABASE_URL from Postgres service and REDIS_URL from Redis service.
STATE_BACKEND=auto
STATE_NAMESPACE=agent_middleware
DATABASE_URL=postgresql://user:password@host:5432/dbname
REDIS_URL=redis://default:password@host:6379

# --- Authentication ---
# Generate production keys: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY_HEADER=X-API-Key
VALID_API_KEYS=REPLACE_WITH_REAL_KEY_1,REPLACE_WITH_REAL_KEY_2

# --- IoT Protocol Bridge ---
MQTT_BROKER_URL=mqtt://mqtt-broker:1883
MQTT_DEFAULT_QOS=1
MQTT_ENFORCE_TOPIC_ACL=true

# --- Telemetry / Autonomous PM ---
TELEMETRY_RETENTION_HOURS=168
AUTO_PR_ENABLED=true
GIT_REMOTE_URL=https://github.com/yourdomain/agent-middleware-api.git
GIT_BRANCH_PREFIX=auto-pm/

# --- Media Engine ---
MAX_UPLOAD_SIZE_MB=500
SUPPORTED_VIDEO_FORMATS=mp4,mov,webm,mkv
CAPTION_LANGUAGE=en

# --- Rate Limiting ---
# Production: 120 req/min per API key
# Premium tier agents get higher limits via key-specific overrides
RATE_LIMIT_PER_MINUTE=120
