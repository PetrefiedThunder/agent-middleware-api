# Agent-Native Middleware API — Environment Configuration
# Copy this to .env and fill in your values

# --- Application ---
APP_NAME="Agent-Native Middleware API"
APP_VERSION="0.1.0"
DEBUG=false

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Durable Runtime State ---
# auto = prefer PostgreSQL, then Redis, else memory
STATE_BACKEND=auto
STATE_NAMESPACE=agent_middleware
DATABASE_URL=
REDIS_URL=

# --- Authentication ---
# Comma-separated API keys. Leave empty for open/development mode.
VALID_API_KEYS=

# --- IoT Protocol Bridge ---
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_DEFAULT_QOS=1
MQTT_ENFORCE_TOPIC_ACL=true

# --- Telemetry / Autonomous PM ---
TELEMETRY_RETENTION_HOURS=168
AUTO_PR_ENABLED=false
GIT_REMOTE_URL=
GIT_BRANCH_PREFIX=auto-pm/

# --- Media Engine ---
MAX_UPLOAD_SIZE_MB=500
SUPPORTED_VIDEO_FORMATS=mp4,mov,webm,mkv
CAPTION_LANGUAGE=en

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=120
