# Agent-Native Middleware API — Environment Configuration
# Copy this to .env and fill in your values

# --- Application ---
APP_NAME="Agent-Native Middleware API"
APP_VERSION="1.2.0"
DEBUG=false

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- CORS ---
# Comma-separated origins (e.g., https://app.example.com,https://dashboard.example.com)
# Use * for development only
CORS_ORIGINS=*

# --- Durable Runtime State ---
# Options: postgres, redis, memory, auto (default: auto)
# Production: use postgres for durable state persistence
STATE_BACKEND=postgres
STATE_NAMESPACE=agent_middleware
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Docker/Railway (optional): run `alembic upgrade head` before uvicorn when this is true
# and DATABASE_URL is set. Use an async URL for Postgres (e.g. postgresql+asyncpg://...).
# RUN_MIGRATIONS_ON_START=true
REDIS_URL=

# --- Authentication ---
# Comma-separated API keys. Leave empty for open/development mode.
VALID_API_KEYS=

# --- IoT Protocol Bridge ---
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_DEFAULT_QOS=1
MQTT_ENFORCE_TOPIC_ACL=true

# --- Telemetry / Autonomous PM ---
TELEMETRY_RETENTION_HOURS=168
AUTO_PR_ENABLED=false
GIT_REMOTE_URL=
GIT_BRANCH_PREFIX=auto-pm/

# --- Media Engine ---
MAX_UPLOAD_SIZE_MB=500
SUPPORTED_VIDEO_FORMATS=mp4,mov,webm,mkv
CAPTION_LANGUAGE=en

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=120

# --- Replay Protection (idempotency / nonce) ---
# Reject replayed state-changing requests that reuse an Idempotency-Key.
# Durable across workers only when STATE_BACKEND is postgres/redis/sqlite.
REPLAY_PROTECTION_ENABLED=true
# Require an Idempotency-Key header on authenticated mutating requests (else 428).
REPLAY_PROTECTION_REQUIRE_KEY=false
REPLAY_PROTECTION_TTL_SECONDS=86400
IDEMPOTENCY_KEY_HEADER=Idempotency-Key

# --- Signed Receipts ---
# Base64 Ed25519 private key seed (32 bytes) for signing ledger receipts.
# Generate: python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
# If empty, an ephemeral key is generated per process (receipts won't verify
# across restarts — set this in production).
RECEIPT_SIGNING_KEY=
# Fallback HMAC secret, used only if the cryptography library is unavailable.
RECEIPT_HMAC_SECRET=

# --- Signed Capability Permits ---
PERMIT_SIGNING_KEY=
PERMIT_HMAC_SECRET=
PERMIT_DEFAULT_TTL_SECONDS=3600
# Require a valid permit on billable MCP tool calls (X-Agent-Permit header).
PERMITS_ENFORCED=false
PERMIT_HEADER=X-Agent-Permit

# --- Behavioral Sandbox ---
# Python execution backend: disabled (default), docker, gvisor, or unsafe_host.
# docker/gvisor provide a real process/network boundary for untrusted code;
# gvisor adds a user-space kernel (runsc runtime, must be installed on host).
BEHAVIORAL_SANDBOX_PYTHON_BACKEND=disabled
BEHAVIORAL_SANDBOX_DOCKER_IMAGE=python:3.12-slim
# Local-dev escape hatch ONLY. Host Python is not a production sandbox.
ALLOW_UNSAFE_HOST_PYTHON_SANDBOX=false

# --- Billing / AgentMoney ---
# 1000 credits = $1.00 USD (1 credit = $0.001)
EXCHANGE_RATE=1000.0

# --- Stripe Payment Processing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- KYC Verification ---
# Require KYC verification before allowing fiat top-ups
KYC_REQUIRED_FOR_TOPUP=false

# --- Notification Service (Resend for Email) ---
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@b2a.dev

# --- Notification Service (Slack) ---
SLACK_WEBHOOK_URL=

# --- Velocity Monitoring ---
# Freeze wallet after this many alert-threshold breaches in 1 hour
VELOCITY_FREEZE_THRESHOLD=3
# Send alert after this many standard deviations above average spend
VELOCITY_ALERT_THRESHOLD=2
# Hourly spend limit in credits (triggers alert/freeze)
VELOCITY_HOURLY_LIMIT=1000.0
# Daily spend limit in credits (triggers alert/freeze)
VELOCITY_DAILY_LIMIT=10000.0

# --- Simulation Mode (per-service) ---
# Default: true for every service. Flip to false only after the matching
# real integration lands (see tracking issue #40).
# Flipping a flag early raises NotImplementedError at the guard site —
# intentional: prevents silent stubs-in-prod.
SIMULATION_MODE_ORACLE=true
SIMULATION_MODE_RED_TEAM=true
SIMULATION_MODE_RTAAS=true
SIMULATION_MODE_MEDIA_ENGINE=true
SIMULATION_MODE_IOT_BRIDGE=true
SIMULATION_MODE_TELEMETRY_PM=true
SIMULATION_MODE_AGENT_COMMS=true
SIMULATION_MODE_CONTENT_FACTORY=true
